# =============================================================================
# Celsius Herbs — local environment variables
#
# Copy this file to `.env` and fill in real values from your Shopify Admin:
#   Shopify Admin → Settings → Apps and sales channels → Develop apps
#     → [your app] → API credentials → Storefront API access token
#
# The .env file is gitignored. NEVER commit real tokens to source control.
# =============================================================================

# Your Shopify store's *.myshopify.com domain (no https://, no trailing slash)
PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Shopify Storefront API access token.
# Storefront tokens are designed to be exposed to the browser — they are scoped
# in Shopify Admin to read-only / public-safe operations (products, menus,
# checkout creation). They are NOT the same as Admin API tokens (which MUST
# remain server-side only).
PUBLIC_SHOPIFY_STOREFRONT_API_TOKEN=your_storefront_api_token_here

# Optional: pin the Storefront API version (default is 2025-01).
# https://shopify.dev/docs/api/usage/versioning
# PUBLIC_SHOPIFY_API_VERSION=2025-01
