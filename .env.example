# =============================================================================
# Celsius Herbs — local environment variables
#
# Copy this file to `.env` and fill in real values from your Shopify Admin:
#   Shopify Admin → Settings → Apps and sales channels → Develop apps
#     → [your app] → API credentials → Storefront API access token
#
# The .env file is gitignored. NEVER commit real tokens to source control.
# =============================================================================

# Your Shopify store's *.myshopify.com domain (no https://, no trailing slash)
PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Shopify Storefront API access token.
# Storefront tokens are designed to be exposed to the browser — they are scoped
# in Shopify Admin to read-only / public-safe operations (products, menus,
# checkout creation). They are NOT the same as Admin API tokens (which MUST
# remain server-side only).
PUBLIC_SHOPIFY_STOREFRONT_API_TOKEN=your_storefront_api_token_here

# Optional: pin the Storefront API version (default is 2025-01).
# https://shopify.dev/docs/api/usage/versioning
# PUBLIC_SHOPIFY_API_VERSION=2025-01

# =============================================================================
# Required for the create-blog-post skill (.claude/skills/create-blog-post/)
# =============================================================================

# OpenRouter API key — routes Perplexity content research calls
# Sign up: https://openrouter.ai/keys
# Pay-as-you-go. The skill uses perplexity/sonar-pro at ~$0.01-0.05 per blog post.
# Rick can later switch to Perplexity direct (https://perplexity.ai/settings/api)
# by changing one URL in the skill — both expose the same chat-completions API.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Gemini API key — used for Stage 5 image generation (NanoBanana)
# Get one at: https://aistudio.google.com/apikey
# The skill uses model: gemini-3.1-flash-image-preview
# Pay-as-you-go. ~$0.10-0.20 per blog post (5 images).
GEMINI_API_KEY=your_gemini_api_key_here

# SurferSEO API key — OPTIONAL. When set, the skill automates Stage 4 (no more
# manual paste-into-Surfer) and runs Stage 8 (auto-audit + revision loop)
# after the preview deploy. When unset, the skill falls back to the manual
# Stage 4 pause (you paste an optimized draft back).
# Get from: https://app.surferseo.com → Settings → API
# Requires Surfer plan with API access.
SURFER_API_KEY=your_surfer_api_key_here

# Optional: minimum Surfer content_score before Stage 8 declares the post
# "passed." Default is 80. Stage 8 keeps revising until the score crosses this
# threshold or one of the guardrails fires.
# SURFER_SCORE_THRESHOLD=80

# Optional: maximum number of revision iterations Stage 8 will run before
# stopping. Default is 4. Each iteration takes ~3-4 minutes (revise + redeploy
# + re-audit) and consumes one Surfer audit credit + light Claude tokens.
# SURFER_MAX_ITERATIONS=4

# Optional guardrails (no env vars to change — encoded in SKILL.md):
# - Stage 8 stops after 20 minutes of wall-clock time regardless of iterations
# - Stage 8 stops early if a revision moves the score by less than 2 points
#   in either direction (plateau detection)
